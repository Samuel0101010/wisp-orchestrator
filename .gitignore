# Dependencies
node_modules/

# Scratch / local-only working dirs
.tmp/
# git-filter-repo rewrite rule inputs (contain private email/username — never commit)
.git-rewrite-*.txt
# Per-session e2e audit scratch scripts (never run by Playwright; testMatch is *.spec.ts)
tests/e2e/audit-*.mjs

# Build outputs
dist/
build/
.turbo/
.vite/
.next/
*.tsbuildinfo

# Test / coverage
coverage/

# Playwright
tests/e2e/test-results/
tests/e2e/playwright-report/
tests/e2e/.last-run.json

# Logs
*.log

# Env
.env
.env.local

# SQLite
*.db
*.db-journal
*.db-wal
*.db-shm

# Runtime data
worktrees/
.claude-plugin-data/
/data/
apps/*/data/

# OS
.DS_Store
Thumbs.db

# Editors
.idea/
.vscode/

# Claude Code session-local state (NOT the plugin manifest at .claude-plugin/)
# Use file-level patterns (not trailing /) so negation works for F9 hook files.
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/skills/
# Local Claude Code hook helpers — ignore everything under .claude/hooks/ except
# the F9 harness-repo bundle file we ship intentionally.
.claude/hooks/*
!.claude/hooks/handler.cjs
# .claude/settings.json is committed intentionally (F9 bundle).

# Impeccable live preview runtime artifacts
.impeccable-live.json
.impeccable-live/

# Local screenshots from design review
mc-*.png
mc-compare*.png
mc-home-*.png
mc-screenshot.png
agents-page.png

# Runtime per-run MCP configs / memory DBs (server only)
apps/dashboard-server/mcp-configs/
apps/dashboard-server/memory/

# Internal planning / audit artifacts (not for public repo)
PROJEKTSTRUKTURPLAN.md
audit-artifacts/
handoff.md
DESIGN.md
# Internal post-mortems / engineering knowledge base (kept local only)
docs/internal/
# Root-only source artwork (published asset lives under docs/assets/)
WISP_Figur.png

# Local Claude session state inside workspaces
apps/*/.claude/

# Failed-test screenshots from interactive runs
tests/e2e/*-failure.png
