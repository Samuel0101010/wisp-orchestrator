{
  "name": "wisp",
  "version": "2.0.8",
  "private": true,
  "description": "WISP — visual team-builder, plan-as-artifact, and live execution graph for autonomous Claude Code agent crews.",
  "keywords": [
    "claude-code",
    "claude-code-plugin",
    "agent-orchestration",
    "multi-agent",
    "dag",
    "kanban",
    "wisp",
    "monorepo"
  ],
  "author": "Samuel Heftberger",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Samuel0101010/wisp-orchestrator.git"
  },
  "bugs": {
    "url": "https://github.com/Samuel0101010/wisp-orchestrator/issues"
  },
  "homepage": "https://github.com/Samuel0101010/wisp-orchestrator#readme",
  "type": "module",
  "engines": {
    "node": ">=20.10",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "inventory": "node scripts/inventory.mjs",
    "inventory:check": "node scripts/inventory.mjs && prettier --write docs/INVENTORY.json && git diff --exit-code -- docs/INVENTORY.json",
    "build": "pnpm -r run build",
    "test": "pnpm --filter \"./packages/**\" --filter \"./apps/**\" --filter \"./tests/compliance\" run test",
    "test:integration": "pnpm -r run test:integration",
    "pretest:e2e": "pnpm --filter dashboard-web build && pnpm --filter dashboard-server build",
    "test:e2e": "pnpm --filter ./tests/e2e run test",
    "encoding:check": "node scripts/check-mojibake.cjs",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "doctor": "node scripts/doctor.mjs",
    "eval": "promptfoo eval -c evals/promptfoo.config.ts",
    "eval:view": "promptfoo view"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.12.0",
    "prettier": "^3.3.3",
    "promptfoo": "^0.121.11",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "better-sqlite3": "^11.10.0"
    }
  }
}
