{
  "name": "agent-harness",
  "version": "1.5.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=20.10",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm -r --parallel run dev",
    "inventory": "node scripts/inventory.mjs",
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "test:integration": "pnpm -r run test:integration",
    "test:e2e": "pnpm --filter ./tests/e2e run test",
    "lint": "eslint .",
    "typecheck": "tsc -b --pretty",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "eval": "promptfoo eval -c evals/promptfoo.config.ts",
    "eval:view": "promptfoo view"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.12.0",
    "prettier": "^3.3.3",
    "promptfoo": "^0.121.11",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "better-sqlite3": "^11.10.0"
    }
  }
}
